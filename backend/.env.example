# AWS
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=

# DynamoDB tables
DYNAMODB_REVIEWS_TABLE=Reviews
DYNAMODB_BATCHES_TABLE=Batches
DYNAMODB_AGGREGATES_TABLE=Aggregates

# S3
S3_BUCKET=review-uploads

# Lambda
LAMBDA_FUNCTION_NAME=sentiment-inference
LAMBDA_BATCH_SIZE=50

# Upload
MAX_UPLOAD_SIZE_MB=50

# App
APP_NAME=Review Analytics API
DEBUG=true
